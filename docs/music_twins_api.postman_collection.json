{
	"info": {
		"_postman_id": "music-twins-api-collection",
		"name": "MusicTwins API",
		"description": "Colección completa para la API de MusicTwins. Incluye autenticación, mensajería, amigos y sincronización de Spotify.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Spotify Login",
					"request": {
						"method": "GET",
						"header": [],
						"url": "http://{{baseUrl}}/api/v1/auth/spotify/login"
					}
				},
				{
					"name": "Get Profile (Me)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": "http://{{baseUrl}}/api/v1/auth/me"
					}
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": "http://{{baseUrl}}/api/v1/auth/logout"
					}
				}
			]
		},
		{
			"name": "Users",
			"item": [
				{
					"name": "Search Users",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "http://{{baseUrl}}/api/v1/users/search?q=query",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "users", "search"],
							"query": [{"key": "q", "value": "query"}]
						}
					}
				}
			]
		},
		{
			"name": "Friends",
			"item": [
				{
					"name": "List Friends",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": "http://{{baseUrl}}/api/v1/friends"
					}
				},
				{
					"name": "Get Requests",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": "http://{{baseUrl}}/api/v1/friends/requests"
					}
				},
				{
					"name": "Send/Action Request",
					"request": {
						"method": "POST",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"toUserId\": \"uuid\",\n  \"action\": \"SEND|ACCEPT|REJECT\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": "http://{{baseUrl}}/api/v1/friends/requests"
					}
				}
			]
		},
		{
			"name": "Conversations",
			"item": [
				{
					"name": "List Conversations",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": "http://{{baseUrl}}/api/v1/conversations"
					}
				},
				{
					"name": "Start Conversation",
					"request": {
						"method": "POST",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"participantId\": \"uuid\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": "http://{{baseUrl}}/api/v1/conversations"
					}
				}
			]
		},
		{
			"name": "Messages",
			"item": [
				{
					"name": "Get Messages",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": {
							"raw": "http://{{baseUrl}}/api/v1/conversations/:id/messages?limit=50&skip=0",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "conversations", ":id", "messages"],
							"query": [
								{ "key": "limit", "value": "50" },
								{ "key": "skip", "value": "0" }
							],
							"variable": [{ "key": "id", "value": "uuid" }]
						}
					}
				},
				{
					"name": "Mark as Read",
					"request": {
						"method": "POST",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"conversationId\": \"uuid\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": "http://{{baseUrl}}/api/v1/messages/read"
					}
				}
			]
		},
		{
			"name": "Spotify",
			"item": [
				{
					"name": "Now Playing",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": "http://{{baseUrl}}/api/v1/spotify/now-playing"
					}
				},
				{
					"name": "Recent Tracks",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": "http://{{baseUrl}}/api/v1/spotify/recent"
					}
				}
			]
		},
		{
			"name": "System",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": "http://{{baseUrl}}/api/v1/health"
					}
				}
			]
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [""]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [""]
			}
		}
	],
	"variable": [
		{ "key": "baseUrl", "value": "musictwinsback.resets.app", "type": "string" },
		{ "key": "token", "value": "YOUR_JWT_TOKEN", "type": "string" }
	]
}
